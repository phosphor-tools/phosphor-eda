{
  "renderMode": "eda",
  "source": {
    "layers": [
      {
        "match": {
          "role": "copper",
          "side": "active"
        },
        "itemKinds": [
          "pad"
        ],
        "purposes": [
          "copper"
        ]
      },
      {
        "match": {
          "role": "silkscreen",
          "side": "active"
        },
        "purposes": [
          "silkscreen",
          "designator"
        ]
      },
      {
        "match": {
          "role": "edge"
        },
        "itemKinds": [
          "board_profile"
        ]
      }
    ],
    "excludeComponents": [
      "R*",
      "C*",
      "L*",
      "FB*"
    ]
  },
  "tokens": {
    "eda.copper.front.fill": "#c2b7a6",
    "eda.copper.back.fill": "#c2b7a6",
    "eda.copper.inner.default.fill": "#d3cabc",
    "eda.silkscreen.front.fill": "#c2b7a6",
    "eda.silkscreen.back.fill": "#c2b7a6",
    "eda.edge.stroke": "#444444",
    "eda.edge.strokeWidthMm": 0.25,
    "highlight.layer.default.fill": "#c00000",
    "highlight.layer.default.opacity": 1,
    "annotation.label.pillVisible": false,
    "annotation.connector.dotVisible": false,
    "annotation.connector.stroke": "#333333",
    "annotation.label.textHalo": "#ffffff",
    "annotation.label.textHaloWidthPt": 3,
    "annotation.label.fontWeight": 700,
    "annotation.connector.strokeWidthPt": 2
  }
}