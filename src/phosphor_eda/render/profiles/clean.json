{
  "renderMode": "realistic",
  "source": {
    "layers": [
      {
        "match": { "role": "copper" },
        "itemKinds": ["pad", "via", "conductor"],
        "purposes": ["copper"]
      },
      { "match": { "role": "solder_mask", "side": "active" } },
      {
        "match": { "role": "silkscreen", "side": "active" },
        "purposes": ["silkscreen", "designator", "value", "user_text"]
      }
    ],
    "excludeComponents": ["R", "C", "L", "TP"]
  },
  "tokens": {
    "realistic.substrate.fill": "#b58b55",
    "realistic.solder_mask.fill": "#1f7a3a",
    "realistic.covered_copper.fill": "#31443a",
    "realistic.covered_copper.opacity": 0.55,
    "realistic.exposed_substrate.fill": "#b58b55",
    "realistic.exposed_copper.fill": "#b87333",
    "realistic.exposed_copper.opacity": 0.85,
    "realistic.silkscreen.fill": "#ffffff",
    "highlight.copper.front.fill": "#ff8a00",
    "highlight.copper.front.opacity": 0.85,
    "highlight.copper.front.stroke": "none",
    "highlight.copper.front.strokeWidthMm": 0,
    "highlight.copper.back.fill": "#5aa7ff",
    "highlight.copper.back.opacity": 0.85,
    "highlight.copper.back.stroke": "none",
    "highlight.copper.back.strokeWidthMm": 0,
    "highlight.copper.inner.default.fill": "#ffe066",
    "highlight.copper.inner.default.opacity": 0.85,
    "highlight.copper.inner.default.stroke": "none",
    "highlight.copper.inner.default.strokeWidthMm": 0,
    "highlight.layer.default.fill": "#ff8a00",
    "highlight.layer.default.opacity": 0.85,
    "highlight.layer.default.stroke": "none",
    "highlight.layer.default.strokeWidthMm": 0,
    "annotation.label.fill": "#fff",
    "annotation.label.textHalo": "#1a5c2a",
    "annotation.label.textHaloWidthPx": 4,
    "annotation.label.fontWeight": 650
  }
}
