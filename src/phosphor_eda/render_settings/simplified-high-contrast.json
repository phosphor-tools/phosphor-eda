{
  "extends": "phosphor:high-contrast",
  "font_size_px": 40,
  "include": {
    "vias": "when-highlighted",
    "layers": [
      {
        "role": "copper",
        "side": "active",
        "objects": {
          "pads": "visible",
          "traces": "when-highlighted",
          "zones": "hidden"
        }
      },
      {
        "role": "silkscreen",
        "side": "active",
        "objects": "visible"
      },
      {
        "role": "fabrication",
        "side": "active",
        "objects": "visible"
      }
    ]
  },
  "highlight_behavior": {
    "overlay": true,
    "dim_unhighlighted": false
  },
  "style_rules": [
    {
      "match": { "annotation": "label" },
      "style": {
        "fill": "#000",
        "text_halo": "#fff",
        "text_halo_width_px": 4,
        "font_weight": 650,
        "pill_visible": false
      }
    },
    {
      "match": { "annotation": "connector" },
      "style": {
        "stroke": "#333",
        "stroke_width_px": 3,
        "dot_visible": false
      }
    }
  ]
}
